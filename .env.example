# Server port for the backend Express server
PORT=3001

# Secret used to sign session cookies — use a long random string in production
SESSION_SECRET=change_me_to_a_long_random_secret

# YouTube OAuth 2.0 credentials (obtained from Google Cloud Console)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# URL of the frontend (used for CORS and OAuth redirect URIs)
FRONTEND_URL=http://localhost:5173
